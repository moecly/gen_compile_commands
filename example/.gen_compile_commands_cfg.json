{
    "source_dir": "/path/to/source",
    "include_dirs": [
        "/path/to/include",
        "/path/to/other/include"
    ],
    "exclude_dirs": [
        ".git",
        ".svn",
        ".hg",
        ".bzr",
        "node_modules",
        "venv",
        ".venv",
        "env",
        "build",
        "dist",
        "target",
        ".cmake",
        "__pycache__",
        ".pytest_cache",
        ".mypy_cache",
        ".idea",
        ".vscode",
        ".vs",
        "bin",
        "obj",
        "out",
        ".deps",
        ".objs"
    ],
    "defines": [
        "-DDEBUG",
        "-DANOTHER_MACRO"
    ],
    "compiler": "gcc",
    "source_files": [
        "**/*.c",
        "**/*.cpp"
    ]
}
