{
    "source_dir": "/path/to/source",
    "include_dirs": [
        "/path/to/include",
        "/path/to/other/include"
    ],
    "exclude_dirs": [
        ".*",
        "build*",
        "test*",
        "node_modules",
        "venv",
        ".venv",
        "env",
        "dist",
        "target",
        "__pycache__",
        "bin",
        "obj",
        "out"
    ],
    "defines": [
        "-DDEBUG",
        "-DANOTHER_MACRO"
    ],
    "compiler": "gcc",
    "source_files": [
        "**/*.c",
        "**/*.cpp"
    ]
}
